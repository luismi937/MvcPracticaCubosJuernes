@model MvcPracticaCubosJuernes.Models.Cubo

@{
    ViewData["Title"] = "Editar Cubo";
    var imagenUrl = string.IsNullOrEmpty(Model.Imagen) || Model.Imagen.StartsWith("/") 
        ? (Model.Imagen ?? "/images/cubos/default.jpg") 
        : $"/images/cubos/{Model.Imagen}";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1 class="display-4 mb-4">Editar Cubo</h1>
        
        <form asp-action="Edit" method="post" enctype="multipart/form-data" class="card p-4 shadow">
            <input type="hidden" name="IdCubo" value="@Model.IdCubo" />
            <input type="hidden" name="Imagen" value="@Model.Imagen" />
            
            <div class="mb-3">
                <label class="form-label">Nombre del Cubo</label>
                <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Modelo</label>
                <input type="text" name="Modelo" class="form-control" value="@Model.Modelo" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Marca</label>
                <input type="text" name="Marca" class="form-control" value="@Model.Marca" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Precio (Euros)</label>
                <input type="number" name="Precio" class="form-control" value="@Model.Precio" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Imagen Actual</label><br/>
                <img src="@imagenUrl" alt="@Model.Nombre" style="max-width: 200px; max-height: 200px;" class="img-thumbnail mb-2" />
            </div>
            
            <div class="mb-3">
                <label class="form-label">Nueva Imagen (opcional)</label>
                <input type="file" name="imagen" class="form-control" accept="image/*" />
                <small class="form-text text-muted">Si no seleccionas una imagen, se mantendra la actual</small>
            </div>
            
            <div class="mt-4">
                <button type="submit" class="btn btn-warning">Actualizar Cubo</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
